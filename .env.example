DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Use SQLite localmente por padrao. Em producao, informe a URL PostgreSQL.
# Exemplo: postgres://usuario:senha@localhost:5432/prontuario
DATABASE_URL=

# Raio padrao permitido para check-in na residencia do paciente.
CHECKIN_DEFAULT_RADIUS_METERS=100
